# PostHog — shared key/host across Better Data OSS + marketing sites; disable by leaving key empty.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

NEXT_PUBLIC_SITE_DOMAIN=commercechain.io
NEXT_PUBLIC_PRODUCT=commercechain
NEXT_PUBLIC_SITE_URL=https://commercechain.io

# Google Analytics — per-stream GA4 measurement ID. Leave unset locally and on preview to suppress gtag.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
